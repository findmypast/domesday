{
  "name": "domesday",
  "version": "2.6.6",
  "description": "Generates UUIDs and registers them to AppIDs in Hashicorp's Vault",
  "main": "src/index.js",
  "scripts": {
    "test": "jest",
    "test:ci": "jest",
    "prepublish-to-npm": "npm config set '//registry.npmjs.org/:_authToken' '${NPM_TOKEN}'",
    "publish-to-npm": "npm publish"
  },
  "bin": {
    "domesday": "./src/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/findmypast/domesday.git"
  },
  "keywords": [
    "toggle",
    "feature",
    "toggle",
    "react",
    "reactjs"
  ],
  "author": "Findmypast <oss@findmypast.com> tech.findmypast.com",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/findmypast/domesday/issues"
  },
  "homepage": "https://github.com/findmypast/domesday#readme",
  "eslintConfig": {
    "extends": "eslint:recommended",
    "env": {
      "node": true,
      "es6": true
    },
    "rules": {
      "quotes": [
        "error",
        "single"
      ],
      "indent": [
        "error",
        2
      ],
      "require-jsdoc": "off",
      "brace-style": [
        "error",
        "stroustrup"
      ]
    }
  },
  "jest": {
    "unmockedModulePathPatterns": [],
    "testEnvironment": "node"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.0.0",
    "async": "^3.2.6",
    "commander": "^12.1.0",
    "node-vault": "^0.10.9",
    "npm-conf": "^1.1.3",
    "uuid": "^8.3.2"
  },
  "overrides": {
    "qs": "^6.14.1"
  }
}
